# Copy this file to ".env" and fill in your real keys.

# Required: get a free key at https://serper.dev
SERPER_API_KEY=your_serper_api_key

# Required: get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: default AI model (user can override from the UI dropdown)
DEFAULT_AI_MODEL=openai/gpt-4o-mini

# Port the server runs on
PORT=5000

# Optional: only needed if you want to identify your app to OpenRouter
OPENROUTER_SITE_URL=http://localhost:5000
OPENROUTER_APP_NAME=Company Research Assistant
